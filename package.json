{
  "name": "gacha-party",
  "version": "4.8.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "worker": "wrangler dev",
    "devhost": "vite --host",
    "workerhost": "wrangler dev --ip 0.0.0.0",
    "build": "vite-ssg build && node scripts/create-spa-fallbacks.mjs && node scripts/verify-ssg-build.mjs",
    "build:ssg": "vite-ssg build",
    "build:verify": "node scripts/verify-ssg-build.mjs",
    "preview": "vite preview",
    "previewhost": "vite preview --host",
    "edgeone:dev": "edgeone makers dev --skip-env-sync",
    "edgeone:test": "node scripts/test-edgeone-functions.mjs",
    "quiz:calibrate": "node scripts/calibrate-personality-scores.mjs",
    "quiz:answer": "node scripts/verify-personality-quiz.mjs",
    "quiz:verify": "node scripts/validate-personality-quiz.mjs",
    "quiz:shuffle": "node scripts/shuffle-personality-quiz.mjs",
    "lint": "eslint . --fix",
    "lint:fix": "eslint \"src/**/*.{vue,js,ts,jsx,tsx}\" --fix",
    "format": "prettier --write \"**/*.{js,json,vue}\"",
    "patch": "npm version patch -m \"docs: 更新补丁版本号v%s\"",
    "minor": "npm version minor -m \"docs: 更新次要版本号v%s\"",
    "major": "npm version major -m \"docs: 更新主要版本号v%s\""
  },
  "dependencies": {
    "@eslint/compat": "^2.1.0",
    "@icon-park/vue-next": "^1.4.2",
    "buffer": "^6.0.3",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "file-saver": "^2.0.5",
    "hono": "^4.12.22",
    "html-to-image": "^1.11.13",
    "pako": "^2.1.0",
    "qrcode": "^1.5.4",
    "tweetnacl": "^1.0.3",
    "vue": "^3.5.34",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@unhead/vue": "^2.1.15",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/eslint-config-prettier": "^10.2.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "eslint-plugin-vue-scoped-css": "^3.1.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "recast": "^0.23.11",
    "vite": "^8.0.14",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vite-ssg": "^28.3.0"
  },
  "allowScripts": {
    "fsevents@2.3.3": true
  },
  "overrides": {
    "workbox-build": {
      "source-map": "0.7.6"
    }
  }
}
